# Copia este archivo como ".env" y pega tu API key de Anthropic.
# Consíguela en https://console.anthropic.com/  (Settings -> API Keys)
#
# ADVERTENCIA: con esta opción la key queda expuesta en el navegador.
# Úsala solo para pruebas locales. En producción, usa un backend/proxy.

VITE_ANTHROPIC_API_KEY=

# Opcional: permite buscar posts publicos de LinkedIn con Apify/HarvestAPI desde el backend local.
# No uses prefijo VITE_ para este token: debe quedarse privado en el servidor.
APIFY_TOKEN=
